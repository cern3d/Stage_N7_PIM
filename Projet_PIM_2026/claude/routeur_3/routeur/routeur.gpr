project Routeur is

   for Source_Dirs use ("src");
   for Object_Dir  use "obj";
   for Exec_Dir    use ".";

   -- Deux exécutables : routeur_LL (cache liste) et routeur_LA (cache trie)
   for Main use ("routeur_ll.adb", "routeur_la.adb");

   package Compiler is
      for Default_Switches ("Ada") use
         ("-g",       -- informations de débogage
          "-gnata",   -- activer les assertions (pragma Assert)
          "-gnatwa",  -- tous les avertissements
          "-gnaty");  -- vérification du style
   end Compiler;

   package Linker is
      for Default_Switches ("Ada") use ("-g");
   end Linker;

end Routeur;
